# Copy to .env.local and fill in as needed.

# --- Data source toggle (client) --------------------------------------------
# Leave UNSET to auto-pick: mock data during `vite dev`, live data in a
# production build. Force it explicitly if you prefer:
#   VITE_USE_MOCK_DATA=true    # always mock
#   VITE_USE_MOCK_DATA=false   # always live (needs the proxy + key below)
# VITE_USE_MOCK_DATA=

# --- Fair Fuel Open Data API (server-side, SECRET) --------------------------
# The x-consumer-id issued by Service Victoria. Used ONLY by the serverless
# proxy in api/stations.js — it is never exposed to the browser. Set this in
# your Vercel project's Environment Variables (and in .env.local for `vercel dev`).
FAIR_FUEL_CONSUMER_ID=

# --- Supabase (optional, for future features) -------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
