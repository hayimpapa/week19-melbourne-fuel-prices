# Copy to .env.local and fill in as needed.

# Data source toggle. Defaults to mock data. Set to "false" only once the
# live Servo Saver (Service Victoria) API is wired up in src/api/fuelApi.js.
VITE_USE_MOCK_DATA=true

# Supabase (used later as a proxy for the Servo Saver API to keep the
# Consumer ID off the client). Safe to leave blank while on mock data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
